# Clerk (required)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# Optional alias supported by the app as well
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# API URL — set when API is on a different domain than the website
# Leave as /api when frontend + backend share one HTTPS domain (recommended)
VITE_API_BASE=/api

# For separate API host only, e.g.:
# VITE_API_BASE=https://vizrr-api.onrender.com/api
