# Copy to .env and set keys as needed
PORT=4000
AI_PROVIDER=local
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<dbname>?retryWrites=true&w=majority
MONGODB_DB_NAME=vizrr
MONGODB_TLS=true

# Comma-separated allowed front-end origins (add your HTTPS URL after deploy)
# CORS_ORIGIN=https://vizrr.onrender.com,http://localhost:5173,capacitor://localhost

# Clerk, Cloudinary, etc. — add your production keys here
CLERK_SECRET_KEY=
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<dbname>?retryWrites=true&w=majority
MONGODB_DB_NAME=vizrr
MONGODB_TLS=true
