{
  "name": "cake-app",
  "version": "1.0.0",
  "scripts": {
    "build": "npm install --prefix client --include=dev && npm run build --prefix client && npm install --prefix server --omit=dev --legacy-peer-deps",
    "start": "npm start --prefix server",
    "app:android": "npm run app:android --prefix client",
    "app:iphone": "npm run app:iphone --prefix client",
    "app:ios": "npm run app:ios --prefix client",
    "app:windows": "npm run app:windows --prefix client"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cloudinary": "^2.10.0"
  }
}
